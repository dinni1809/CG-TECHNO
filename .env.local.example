# ── SMTP Configuration ─────────────────────────────────────────────────────
# Gmail SMTP — use a Gmail App Password, not your account password
# Setup: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cgtechnoelectronics@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# ── Email Destinations ────────────────────────────────────────────────────
# Contact form submissions go here
CONTACT_EMAIL_TO=cgtechnoelectronics@gmail.com
# Job applications go here
CAREERS_EMAIL_TO=cgtechnoelectronics@gmail.com

# ── Application Config ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
