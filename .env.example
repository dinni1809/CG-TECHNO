# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL="postgresql://username:password@host:port/dbname?sslmode=require"

# ============================================================================
# NEXTAUTH AUTHENTICATION CONFIG
# ============================================================================
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_PASSWORD="your_admin_dashboard_password_here"

# ============================================================================
# SPRINT 6: EMAIL INFRASTRUCTURE CONFIGURATION (RESEND)
# ============================================================================

# Resend API Key (starts with re_)
# Required for production. In development, if missing, email functions will log errors but not throw exceptions.
RESEND_API_KEY="re_your_api_key_here"

# Sender Email Address (e.g. no-reply@cgtechnoelectronics.com)
# For local development with a Resend sandbox account, set this to: onboarding@resend.dev
EMAIL_FROM="onboarding@resend.dev"

# Comma-separated list of Admin/HR recipient email addresses
# e.g., ADMIN_EMAILS="owner@cgtechno.com,hr@cgtechno.com,sales@cgtechno.com"
ADMIN_EMAILS="cgtechnoelectronics@gmail.com"

# Fallback single Admin recipient email address
# Used if ADMIN_EMAILS is not defined or is empty.
ADMIN_EMAIL="cgtechnoelectronics@gmail.com"
