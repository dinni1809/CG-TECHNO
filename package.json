{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build:web": "pnpm --filter @cg-techno/web build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@swc/core",
      "msw",
      "unrs-resolver",
      "prisma",
      "@prisma/engines"
    ]
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.27.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
